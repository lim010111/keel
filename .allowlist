# keel/.allowlist — what sync.sh mirrors from ~/.claude.
#
# Only the user's own authored content goes here. Third-party skills,
# the gstack submodule, and plugins are referenced in docs/DEPENDENCIES.md
# — never copied into this repo (see docs/adr/0002).
#
# Paths are relative to $CLAUDE_DIR (default: ~/.claude).

# --- Skills (authored) ---
skills/ai-readiness-cartography
skills/audit-and-write-readme
skills/ci-setup
skills/daily-dev-log
skills/daily-token-report
skills/session-dev-log
skills/setup-status-harness
skills/status
skills/tech-blog
skills/third-party-review

# --- Hooks ---
hooks/tdd_guard.py
hooks/tdd_keyword.py
hooks/tdd_mark.py
hooks/tdd_verify.py
hooks/session_devlog.py
hooks/test_session_devlog.py
hooks/test_tdd_hooks.py

# --- Scripts ---
scripts/status.py
scripts/sound_complete.sh
scripts/sound_permission.sh

# --- Agents (definitions only; agent-memory/ is intentionally excluded) ---
agents/ci-researcher.md
agents/korean-context-writer.md

# --- Config ---
CLAUDE.md
statusline.sh
settings.json

# --- Deliberately excluded ---
# Authored content that is keel-maintenance tooling, not harness content
# (see docs/adr/0002). detect-drift.sh reads these so they stop being
# flagged as untracked drift.
# exclude: skills/keel-update
